---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import ServiceArea from '../../components/services/ServiceArea.astro';
import ProcessSteps from '../../components/services/ProcessSteps.astro';
import CtaBanner from '../../components/home/CtaBanner.astro';
import bgImage from '../../assets/stock/coworking-1.png';

const servicesJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "provider": {
    "@type": "ProfessionalService",
    "name": "MAKOConsult",
    "url": "https://makoconsult.com"
  },
  "name": "Strategische Marketing-Leistungen",
  "description": "Vier vernetzte Bereiche strategischen Marketings: Markenpositionierung, Kommunikationsstrategie, Daten & Analytics und B2B Sales & Marketing Alignment.",
  "areaServed": "Europe",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Strategische Marketing-Leistungen",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Brand Strategy & Modernisation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Communication & Channel Strategy" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Data & AI-Enabled Marketing" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "B2B Growth & ABM Strategy" } },
    ]
  }
};

const services = [
  {
    icon: 'service-brand',
    title: 'Markenstrategie & Modernisierung',
    subtitle: 'Positionierung · Identität · Botschaften',
    body: "Die meisten Marken scheitern nicht am Design. Sie scheitern, weil die Positionierung unklar ist, die Botschaften inkonsistent sind oder die Marke nicht mehr widerspiegelt, wer das Unternehmen geworden ist. Ich helfe Ihnen, diese Lücke zu schließen. Ich entwickle eine Markenpositionierung, die kommerziell fundiert, klar im Wettbewerb positioniert und auf Bestand ausgelegt ist, und unterstütze Ihr Team dabei, diese Positionierung an jedem Touchpoint richtig umzusetzen.",
    bullets: [
      "Eine klar definierte Positionierung, die Sie in Ihrem Markt differenziert und Ihrem Team eine gemeinsame Richtung gibt. Kein Claim, sondern ein strategisches Fundament.",
      "Ein Messaging-Framework, das auf Ihre tatsächlichen Zielgruppen abgestimmt ist, damit jede Kommunikation, vom Pitch bis zur Produktseite, das Gleiche sagt, nur anders.",
      "Unabhängige Agenturauswahl und Implementierungsbegleitung, damit die Strategie nicht zwischen Vorstandsetage und Briefing verloren geht.",
    ],
    tags: ['Brand Positioning', 'Value Proposition', 'Messaging Framework', 'Competitive Differentiation', 'Target Audience', 'Visual Identity Direction', 'Brand Architecture', 'Agency Oversight'],
  },
  {
    icon: 'service-communication',
    title: 'Kommunikations- & Kanalstrategie',
    subtitle: 'Botschaften · Kanäle · Zielgruppen',
    body: "Das Problem ist selten, dass Unternehmen zu wenig kommunizieren. Das Problem ist, dass sie die falschen Dinge sagen, auf den falschen Kanälen, zu Zielgruppen, die nicht zuhören. Ich entwickle Kommunikationsstrategien, deren Botschaft relevant ist und der Kanalmix eine klare Logik hat. Meine Arbeit endet vor der Umsetzung. Das bedeutet: keine Interessenkonflikte, keine Medienprovisionen, kein Anreiz, etwas anderes zu empfehlen als das, was wirkt.",
    bullets: [
      "Ein strukturiertes Zielgruppen-Segmentierungsmodell und Messaging-Framework, damit jede Stakeholder-Gruppe eine Kommunikation erhält, die ihre tatsächlichen Prioritäten anspricht, nicht eine generische Version Ihrer Homepage.",
      "Eine Kanalstrategie mit klarer Begründung: wo investieren, wo kürzen und wie die Kanäle über die Customer Journey zusammenspielen.",
      "Eine Kampagnenarchitektur, die Ihr internes Team oder Ihre Agentur direkt umsetzen kann, ohne das strategische Denken dahinter erst rekonstruieren zu müssen.",
    ],
    tags: ['Audience Segmentation', 'Channel Mix', 'Content Framework', 'Media Planning', 'Tone of Voice', 'Campaign Architecture', 'Buyer Journey', 'Message Hierarchy'],
  },
  {
    icon: 'service-data',
    title: 'Daten- & KI-gestütztes Marketing',
    subtitle: 'Analytics · KI · Entscheidungsgrundlagen',
    body: "Die meisten Marketingteams erheben mehr Daten, als sie nutzen. Die Dashboards existieren, die Erkenntnisse nicht. Ich helfe Unternehmen, Daten in echte Entscheidungsgrundlagen zu verwandeln, indem ich verbinde, was gemessen wird, mit dem, was wirklich zählt. Ich helfe Teams auch dabei, KI über den reinen Texteinsatz hinaus als echten strategischen Vorteil zu nutzen: durch Workflows, Governance-Frameworks und praxisnahe Fähigkeiten, die Zeit sparen und das Denken schärfen.",
    bullets: [
      "Ein KPI-Framework und eine Datenarchitektur, die auf Ihre kommerziellen Ziele ausgerichtet sind, damit Reporting aufhört, ein Ritual zu sein, und anfängt, nützlich zu werden.",
      "Ein klares Bild davon, wo KI die Leistung Ihres Teams realistisch verbessern kann: schnellere Recherche, schärfere Briefings, bessere Zielkundenintelligenz, ohne Hype.",
      "Maßgeschneiderte KI-Workflows und praxisnahe Schulungen, die Ihr Team tatsächlich nutzen kann. Keine theoretische Roadmap, die in der Schublade landet.",
    ],
    tags: ['KPI Framework', 'Marketing Analytics', 'AI Strategy', 'Workflow Automation', 'Data Architecture', 'Performance Measurement', 'AI Training', 'Decision Intelligence'],
  },
  {
    icon: 'service-b2b',
    title: 'B2B-Wachstum & ABM-Strategie',
    subtitle: 'ABM · Pipeline · Sales-Alignment',
    body: "Wenn Sales und Marketing nicht aufeinander abgestimmt sind, leidet die Pipeline. Und jede Seite gibt der anderen die Schuld. Ich helfe B2B-Unternehmen, die Systeme aufzubauen, die diese Lücke schließen: Account-based-Marketing-Strategien, die die richtigen Unternehmen ansprechen, die richtigen Personen darin erreichen und dem Vertrieb ein Framework an die Hand geben, das auch wirklich genutzt wird. Ich entwickle die Strategie und begleite die Implementierung, führe aber keine Kampagnen durch und ersetze nicht Ihr Vertriebsteam.",
    bullets: [
      "Ein klar definiertes ICP mit Account-Priorisierung und Buying-Committee-Mapping, damit Ihr Team genau weiß, wen es ansprechen soll, warum und mit welcher Botschaft in welcher Phase.",
      "Eine Sales-und-Marketing-Funnel-Strategie mit gemeinsamer Qualifizierungslogik, ohne die Grauzone zwischen Marketing-Übergabe und Vertriebsnachverfolgung.",
      "ABM-Playbooks, die Ihr Team eigenständig einsetzen kann, mit klarer Governance, Tracking und genug Flexibilität, um sich anzupassen, während Sie lernen.",
    ],
    tags: ['Account-Based Marketing', 'ICP Definition', 'Buying Committee Mapping', 'Pipeline Strategy', 'Sales & Marketing Alignment', 'Lead Qualification', 'ABM Playbooks', 'Revenue Marketing'],
  },
];
---

<BaseLayout
  title="Strategische Marketing-Leistungen"
  description="Vier vernetzte Bereiche strategischen Marketings: Markenpositionierung, Kommunikationsstrategie, Daten & Analytics und B2B Sales & Marketing Alignment."
  lang="de"
  canonicalPath="/services"
  jsonLd={servicesJsonLd}
>
  <section class="relative py-24 sm:py-32 overflow-hidden">
    <Image src={bgImage} alt="" class="absolute inset-0 w-full h-full object-cover" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
    <div class="absolute inset-0 bg-graphite/55"></div>
    <Container class="relative">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-solar mb-6">Was ich tue</p>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white leading-tight mb-8">
          Strategische Marketing-Leistungen
        </h1>
        <p class="text-lg sm:text-xl text-white/85 leading-relaxed">
          Ich arbeite in vier vernetzten Bereichen strategischen Marketings. Jeder erschließt eine andere Dimension, die Marketing wirkungsvoll macht. Die meisten Projekte beginnen mit Positionierung und entwickeln sich von dort weiter.
        </p>
      </div>
    </Container>
  </section>

  <section class="py-20 sm:py-24">
    <Container>
      <SectionHeading eyebrow="Leistungsbereiche">
        Womit ich Ihnen helfen kann
      </SectionHeading>
      <div class="space-y-16 mt-12">
        {services.map((service, i) => (
          <ServiceArea {...service} />
        ))}
      </div>
    </Container>
  </section>

  <ProcessSteps lang="de" />

  <CtaBanner
    lang="de"
    heading="Bereit, strategische Klarheit in Ihr Marketing zu bringen?"
    body="Beginnen Sie mit einem Gespräch über Ihre Situation und wie ein strategisches Fundament helfen kann."
  />
</BaseLayout>
