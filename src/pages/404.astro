---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | MAKOConsult</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header lang="en" canonicalPath="/" />
    <main id="main" class="flex-1 flex items-center">
      <Container>
        <div class="text-center py-24">
          <p class="text-sm font-semibold uppercase tracking-widest text-ember mb-4">404</p>
          <h1 class="font-heading text-4xl sm:text-5xl font-bold text-graphite mb-6">Page Not Found</h1>
          <p class="text-steel text-lg mb-10 max-w-md mx-auto">
            The page you're looking for doesn't exist or has been moved.
          </p>
          <Button href="/en/">Back to Home</Button>
        </div>
      </Container>
    </main>
    <Footer lang="en" canonicalPath="/" />
  </body>
</html>
