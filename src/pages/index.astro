---
// This page serves as a language detection redirect.
// Static site — uses client-side JS to detect browser language.
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <script is:inline>
      const lang = navigator.language || navigator.userLanguage || 'en';
      const isGerman = lang.startsWith('de');
      window.location.replace(isGerman ? '/de/' : '/en/');
    </script>
    <meta http-equiv="refresh" content="0;url=/en/" />
  </head>
  <body></body>
</html>
