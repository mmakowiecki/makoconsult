---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
---

<BaseLayout
  title="Imprint"
  description="Legal information and imprint for MAKO Consult, Hamburg, Germany."
  lang="en"
  canonicalPath="/imprint"
>
  <section class="py-24 sm:py-32">
    <Container>
      <div class="prose prose-lg max-w-3xl">
        <h1>Imprint</h1>
        <p class="text-steel">Information in accordance with § 5 TMG (German Telemedia Act)</p>

        <h2>Service Provider</h2>
        <p>
          Michael Makowiecki<br />
          MAKO Consult<br />
          Hamburg, Germany
        </p>

        <h2>Contact</h2>
        <p>
          Email: <a href="mailto:hello@makoconsult.com">hello@makoconsult.com</a>
        </p>

        <h2>VAT Identification Number</h2>
        <p>[VAT ID to be added]</p>

        <h2>Responsible for Content</h2>
        <p>
          Michael Makowiecki<br />
          (Address as above)
        </p>

        <h2>Dispute Resolution</h2>
        <p>
          The European Commission provides a platform for online dispute resolution (ODR):
          <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener noreferrer">
            https://ec.europa.eu/consumers/odr
          </a>
        </p>
        <p>We are not willing or obliged to participate in dispute resolution proceedings before a consumer arbitration board.</p>
      </div>
    </Container>
  </section>
</BaseLayout>
