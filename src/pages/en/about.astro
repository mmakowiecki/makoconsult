---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CareerNarrative from '../../components/about/CareerNarrative.astro';
import CtaBanner from '../../components/home/CtaBanner.astro';

const aboutJsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "mainEntity": {
    "@type": "Person",
    "name": "Michael Makowiecki",
    "jobTitle": "Strategic Marketing Consultant",
    "worksFor": { "@type": "Organization", "name": "MAKOConsult" },
    "url": "https://www.linkedin.com/in/makoconsult/",
    "knowsAbout": ["Brand Strategy", "B2B Marketing", "Communication Strategy", "Marketing Analytics", "Account-Based Marketing"],
    "address": { "@type": "PostalAddress", "addressLocality": "Hamburg", "addressCountry": "DE" }
  }
};
---

<BaseLayout
  title="About Michael Makowiecki"
  description="Strategic marketing consultant with 15+ years across global brands, agencies, and markets. Helping B2B companies build marketing clarity through discovery-first consulting."
  lang="en"
  canonicalPath="/about"
  jsonLd={aboutJsonLd}
>
  <CareerNarrative lang="en" />
  <CtaBanner
    lang="en"
    heading="Let's Talk About Your Challenges"
    body="Ready to build strategic clarity for your marketing? Start with a conversation to discuss your situation and explore how a strategic foundation can help."
  />
</BaseLayout>
