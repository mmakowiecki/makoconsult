---
import Icon from '../ui/Icon.astro';

interface Props {
  icon: string;
  title: string;
  subtitle?: string;
  body: string;
  bullets?: string[];
  tags?: string[];
  reversed?: boolean;
}

const { icon, title, subtitle, body, bullets = [], tags = [], reversed = false } = Astro.props;
const hasExpandable = bullets.length > 0 || tags.length > 0;
---

<div class="service-area grid md:grid-cols-[auto_1fr] gap-8 items-start rounded-sm bg-ember p-8">
  <div class="flex-shrink-0">
    <Icon name={icon} class="w-16 h-16 text-white [&>svg]:w-16 [&>svg]:h-16" />
  </div>
  <div>
    <h3 class="font-heading text-2xl font-bold text-white mb-1">{title}</h3>
    {subtitle && <p class="text-white/60 text-sm font-medium mb-4">{subtitle}</p>}
    <p class="text-white/80 leading-relaxed text-lg">{body}</p>
    {hasExpandable && (
      <details class="service-details mt-4">
        <summary class="mt-6 bg-white/15 text-white text-sm font-semibold px-5 py-2 rounded-full hover:bg-solar hover:text-graphite transition-all duration-200 inline-flex items-center gap-2 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
          <span class="toggle-label">More</span>
          <svg class="w-4 h-4 transition-transform toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="mt-4">
          {bullets.length > 0 && (
            <ul class="space-y-3 mb-6">
              {bullets.map((bullet) => (
                <li class="text-white/80 leading-relaxed flex gap-3">
                  <span class="text-solar mt-1 shrink-0">&#x2022;</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          )}
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {tags.map((tag) => (
                <span class="inline-block text-xs font-medium bg-white/15 text-white/90 px-3 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </details>
    )}
  </div>
</div>

<style>
  .service-details[open] .toggle-label {
    display: none;
  }
  .service-details[open] summary::before {
    content: 'Less';
  }
  .service-details[open] .toggle-arrow {
    transform: rotate(180deg);
  }
  .service-details summary {
    user-select: none;
  }
</style>
