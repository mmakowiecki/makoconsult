---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  en: {
    eyebrow: 'How I Work With You',
    heading: 'A Structured Path to Clarity',
    steps: [
      { icon: 'process-discovery', title: 'Discovery', body: 'Analysis: I dig into your business, market and internal dynamics to identify friction, gaps and unused potential and present an action plan.' },
      { icon: 'process-strategy', title: 'Strategy', body: 'Based on discovery findings, I build a strategy specifically for your context with a clear rationale for every decision.' },
      { icon: 'process-delivery', title: 'Delivery', body: "I deliver frameworks your team can execute, with clear handoff and training. Not 100-slide decks that sit in a drawer." },
      { icon: 'process-support', title: 'Support', body: 'Optional ongoing advisory as you implement. I answer questions, adjust as you learn, and keep strategy on track.' },
    ],
  },
  de: {
    eyebrow: 'Wie wir zusammenarbeiten',
    heading: 'Ein strukturierter Weg zur Klarheit',
    steps: [
      { icon: 'process-discovery', title: 'Discovery', body: 'Analyse: Ich tauche tief in Ihr Unternehmen, Ihren Markt und Ihre internen Dynamiken ein, um Reibungspunkte, Lücken und ungenutztes Potenzial zu identifizieren.' },
      { icon: 'process-strategy', title: 'Strategie', body: 'Auf Basis der Discovery-Erkenntnisse entwickle ich eine Strategie, die spezifisch für Ihren Kontext ist, mit klarer Begründung für jede Entscheidung.' },
      { icon: 'process-delivery', title: 'Übergabe', body: 'Ich liefere Frameworks, die Ihr Team in der Praxis anwenden kann, mit klarer Übergabe und Einführung. Keine 100-Folien-Präsentationen, die in der Schublade landen.' },
      { icon: 'process-support', title: 'Begleitung', body: 'Optionale laufende Beratung während der Umsetzung. Ich beantworte Fragen, passe Ansätze an und halte die Strategie auf Kurs.' },
    ],
  },
};

const c = content[lang];
---

<section class="py-20 sm:py-24 bg-warm-white">
  <Container>
    <SectionHeading eyebrow={c.eyebrow} align="center">
      {c.heading}
    </SectionHeading>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
      {c.steps.map((step, i) => (
        <div class="text-center border-2 border-gray-200 rounded-lg p-8">
          <div class="font-heading text-6xl font-bold text-ember mb-4">
            {i + 1}
          </div>
          <h4 class="font-heading text-lg font-bold text-graphite mb-3">{step.title}</h4>
          <p class="text-steel text-sm leading-relaxed">{step.body}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
