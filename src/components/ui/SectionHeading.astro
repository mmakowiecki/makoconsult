---
interface Props {
  eyebrow?: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { eyebrow, subtitle, align = 'left' } = Astro.props;
const alignClass = align === 'center' ? 'text-center' : '';
---

<div class:list={['mb-12', alignClass]}>
  {eyebrow && (
    <p class="text-sm font-semibold uppercase tracking-widest text-ember mb-3">{eyebrow}</p>
  )}
  <h2 class="font-heading text-3xl sm:text-4xl font-bold text-graphite">
    <slot />
  </h2>
  {subtitle && (
    <p class="mt-4 text-lg text-steel max-w-2xl" class:list={[align === 'center' && 'mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
