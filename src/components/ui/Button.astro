---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const variants = {
  primary: 'bg-ember text-white hover:bg-ember-dark',
  secondary: 'bg-graphite text-white hover:bg-steel-dark',
  outline: 'border-2 border-ember text-ember hover:bg-ember hover:text-white',
};
---

<a
  href={href}
  class:list={[
    'inline-block px-8 py-3 font-medium rounded-sm transition-colors duration-200 text-center',
    variants[variant],
    className,
  ]}
>
  <slot />
</a>
