---
import Container from '../ui/Container.astro';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  en: {
    eyebrow: 'How I Work',
    heading: 'What Makes This Different',
    points: [
      {
        title: 'No inflated 100-slide strategy decks',
        body: 'You get frameworks your team can actually execute, with clear handoff and training.',
      },
      {
        title: 'No universal solutions sold to every client',
        body: 'Every strategy is built specifically for your context, market and challenges.',
      },
      {
        title: 'No execution conflicts of interest',
        body: "I don't sell media or run your campaigns, which means honest recommendations, not upsells.",
      },
    ],
  },
  de: {
    eyebrow: 'Wie ich arbeite',
    heading: 'Was diesen Ansatz unterscheidet',
    points: [
      {
        title: 'Keine aufgeblähten 100-Folien-Strategiepräsentationen',
        body: 'Sie erhalten Frameworks, die Ihr Team tatsächlich umsetzen kann, mit klarer Übergabe und Schulung.',
      },
      {
        title: 'Keine universellen Lösungen für jeden Kunden',
        body: 'Jede Strategie wird speziell für Ihren Kontext, Markt und Ihre Herausforderungen entwickelt.',
      },
      {
        title: 'Keine Interessenkonflikte bei der Umsetzung',
        body: 'Ich verkaufe keine Medien und führe keine Kampagnen durch — das bedeutet ehrliche Empfehlungen, keine Upsells.',
      },
    ],
  },
};

const c = content[lang];
---

<section class="py-20 sm:py-24 bg-graphite">
  <Container>
    <div class="mb-12 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-solar mb-3">{c.eyebrow}</p>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white">{c.heading}</h2>
    </div>

    <div class="grid sm:grid-cols-3 gap-8 mt-12">
      {c.points.map((point) => (
        <div class="border border-white/15 rounded-sm p-8">
          <h3 class="font-heading text-lg font-bold text-solar mb-3">{point.title}</h3>
          <p class="text-white/70 leading-relaxed">{point.body}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
