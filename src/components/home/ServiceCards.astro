---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Icon from '../ui/Icon.astro';
import { getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  en: {
    eyebrow: 'What I Do',
    heading: 'Four Areas, One Foundation',
    intro: 'Strategic clarity gives you a plan and a direction.',
    link: 'Explore All Services',
    cards: [
      { icon: 'service-brand', title: 'Brand & Positioning', body: "Build positioning that differentiates you in your market. Not just a tagline, but a strategic foundation your team can execute against." },
      { icon: 'service-communication', title: 'Communication Strategy', body: 'Translate strategy into messaging that resonates: across channels, audiences, and touchpoints.' },
      { icon: 'service-data', title: 'AI, Data & Analytics', body: "Identify the data points that really matter and turn them into decisions. Not dashboards that look impressive but don't guide action." },
      { icon: 'service-b2b', title: 'B2B Sales & Marketing', body: 'Build the systems that align sales and marketing: shared ICPs, clear handoffs, and ABM strategies that actually get followed.' },
    ],
  },
  de: {
    eyebrow: 'Was ich tue',
    heading: 'Vier Bereiche, ein Fundament',
    intro: 'Strategische Klarheit schafft Orientierung und macht Entscheidungen einfacher.',
    link: 'Alle Leistungen ansehen',
    cards: [
      { icon: 'service-brand', title: 'Marke & Positionierung', body: 'Positionierung, die Sie in Ihrem Markt klar differenziert. Kein Claim, sondern ein strategisches Fundament, das Ihre Marke trägt.' },
      { icon: 'service-communication', title: 'Kommunikationsstrategie', body: 'Strategie wird zu Botschaften, die wirken. Kanalübergreifend, zielgruppengenau, konsistent.' },
      { icon: 'service-data', title: 'KI, Daten & Analytics', body: 'Die Datenpunkte identifizieren, die wirklich zählen, und daraus Entscheidungen ableiten. Keine Dashboards, die beeindrucken, aber nicht lenken.' },
      { icon: 'service-b2b', title: 'B2B Sales & Marketing', body: 'Die Systeme aufbauen, die Sales und Marketing wirklich zusammenbringen. Gemeinsame ICPs, klare Übergaben, ABM-Strategien, die auch umgesetzt werden.' },
    ],
  },
};

const c = content[lang];
---

<section class="py-20 sm:py-24">
  <Container>
    <SectionHeading eyebrow={c.eyebrow}>
      {c.heading}
    </SectionHeading>

    <div class="grid sm:grid-cols-2 gap-8 mt-12">
      {c.cards.map((card) => (
        <div class="p-8 rounded-sm bg-ember flex gap-6 items-start">
          <Icon name={card.icon} class="w-12 h-12 shrink-0 text-white [&>svg]:w-12 [&>svg]:h-12" />
          <div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">{card.title}</h3>
            <p class="text-white/80 leading-relaxed">{card.body}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12">
      <a
        href={getLocalizedPath(lang, '/services')}
        class="text-ember font-medium hover:text-ember-dark transition-colors inline-flex items-center gap-2"
      >
        {c.link}
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </Container>
</section>
