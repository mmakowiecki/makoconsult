---
import { Image } from 'astro:assets';
import Container from '../ui/Container.astro';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;

import logo4flow from '../../assets/logos/clients/4flow.jpg';
import logoBacardi from '../../assets/logos/clients/bacardi.png';
import logoBat from '../../assets/logos/clients/bat.png';
import logoBombay from '../../assets/logos/clients/bombay-sapphire.png';
import logoGlo from '../../assets/logos/clients/glo.png';
import logoGreyGoose from '../../assets/logos/clients/grey-goose.png';
import logoImperial from '../../assets/logos/clients/imperial-brands.png';
import logoMetro from '../../assets/logos/clients/metro.png';
import logoScholz from '../../assets/logos/clients/scholz-friends.png';
import logoServiceplan from '../../assets/logos/clients/serviceplan.png';
import logoTchibo from '../../assets/logos/clients/tchibo.png';
import logoVodafone from '../../assets/logos/clients/vodafone.png';
import logoWeischer from '../../assets/logos/clients/weischer.png';
import logoVorwerk from '../../assets/logos/clients/vorwerk.svg';

const clients = [
  { name: '4flow', src: logo4flow },
  { name: 'Bacardi', src: logoBacardi },
  { name: 'BAT', src: logoBat },
  { name: 'Bombay Sapphire', src: logoBombay, class: 'h-8 sm:h-10' },
  { name: 'glo', src: logoGlo },
  { name: 'Grey Goose', src: logoGreyGoose, class: 'h-12 sm:h-14' },
  { name: 'Imperial Brands', src: logoImperial },
  { name: 'METRO', src: logoMetro },
  { name: 'Scholz & Friends', src: logoScholz },
  { name: 'Serviceplan', src: logoServiceplan, class: 'h-10 sm:h-12' },
  { name: 'Tchibo', src: logoTchibo },
  { name: 'Vodafone', src: logoVodafone },
  { name: 'Vorwerk', src: logoVorwerk },
  { name: 'Weischer', src: logoWeischer, class: 'h-6 sm:h-8' },
];
---

<section class="py-16 border-y border-gray-100">
  <Container>
    <p class="text-sm font-semibold uppercase tracking-widest text-ember mb-8 text-center">{lang === 'de' ? 'Erfahrung mit' : 'Experience with'}</p>
  </Container>
  <div class="overflow-hidden">
    <div class="logo-scroll flex items-center gap-16 w-max">
      {[...clients, ...clients].map(({ name, src, class: customClass }) => {
        const cls = `${customClass || 'h-8 sm:h-10'} w-auto shrink-0 object-contain grayscale opacity-60`;
        return typeof src === 'string'
          ? <img src={src} alt={name} class={cls} />
          : <Image src={src} alt={name} height={56} class={cls} />
      })}
    </div>
  </div>
</section>

<style>
  .logo-scroll {
    animation: scroll 40s linear infinite;
  }

  .logo-scroll:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    to {
      transform: translateX(-50%);
    }
  }
</style>
