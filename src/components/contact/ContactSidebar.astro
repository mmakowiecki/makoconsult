---
import type { Lang } from '../../i18n/ui';
import Icon from '../ui/Icon.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  en: {
    basedIn: 'Based in',
    location: 'Hamburg, Germany',
    workingWith: 'Working with',
    audience: 'Companies in tech, FMCG, industrial, and professional services - navigating complexity in positioning, growth, or modernization, and agencies looking for a strategic partner.',
    email: 'Email',
    linkedin: 'LinkedIn Profile',
  },
  de: {
    basedIn: 'Standort',
    location: 'Hamburg, Deutschland',
    workingWith: 'Wen ich berate',
    audience: 'Unternehmen aus Tech, FMCG, Industrie und Professional Services, die Klarheit in Positionierung, Wachstum oder Modernisierung suchen, sowie Agenturen, die einen strategischen Partner brauchen.',
    email: 'E-Mail',
    linkedin: 'LinkedIn-Profil',
  },
};

const c = content[lang];
---

<div class="bg-warm-white rounded-sm p-8">
  <h4 class="font-heading text-lg font-bold text-graphite mb-1">Michael Makowiecki</h4>
  <p class="text-sm text-steel mb-1">Strategic Marketing Consultant</p>
  <p class="text-sm text-steel mb-6">Founder, MAKO Consult</p>

  <div class="space-y-5">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-ember mb-1">{c.basedIn}</p>
      <p class="text-steel">{c.location}</p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-ember mb-1">{c.workingWith}</p>
      <p class="text-steel">{c.audience}</p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-ember mb-1">{c.email}</p>
      <a href="mailto:info@makoconsult.de" class="text-steel hover:text-ember transition-colors">info@makoconsult.de</a>
    </div>
    <div class="pt-2">
      <p class="text-xs font-semibold uppercase tracking-widest text-ember mb-3">{lang === 'en' ? 'Connect with me' : 'Vernetzen wir uns'}</p>
      <a
        href="https://www.linkedin.com/in/makoconsult/"
        target="_blank"
        rel="noopener noreferrer"
        class="block hover:opacity-80 transition-opacity"
        aria-label="LinkedIn"
      >
        <Icon name="linkedin-color" class="w-3/4 [&>svg]:w-full [&>svg]:h-auto" />
      </a>
    </div>
  </div>
</div>
