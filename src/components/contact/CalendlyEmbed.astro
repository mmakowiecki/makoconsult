---
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  en: {
    heading: 'Book a call',
    body: 'A 30-minute conversation to understand your situation and explore how I can help. No commitment, no pressure.',
  },
  de: {
    heading: 'Kostenloses Kennenlerngespräch buchen',
    body: 'Ein 30-minütiges Gespräch, um Ihre Situation zu verstehen und zu erkunden, wie ich helfen kann. Keine Verpflichtung, kein Druck.',
  },
};

const c = content[lang];
---

<div>
  <h3 class="font-heading text-2xl font-bold text-graphite mb-3">{c.heading}</h3>
  <p class="text-steel mb-8">{c.body}</p>

  <div id="cal-inline" style="width:100%;min-height:600px;overflow:scroll;"></div>

  <script type="text/javascript" is:inline>
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://cal.eu/embed.js", "init");

    Cal("init", "30min", { origin: "https://cal.eu" });

    Cal.ns["30min"]("inline", {
      elementOrSelector: "#cal-inline",
      config: { layout: "month_view" },
      calLink: "makoconsult/30min",
    });

    Cal.ns["30min"]("ui", {
      hideEventTypeDetails: false,
      layout: "month_view",
    });
  </script>
</div>
