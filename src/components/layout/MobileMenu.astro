---
import { useTranslations, getLocalizedPath, getAlternateLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
  canonicalPath: string;
}

const { lang, canonicalPath } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);

const navItems = [
  { label: t('nav.home'), canonical: '/' },
  { label: t('nav.services'), canonical: '/services' },
  { label: t('nav.about'), canonical: '/about' },
  { label: t('nav.contact'), canonical: '/contact' },
];
---

<!-- Hamburger button -->
<button
  id="mobile-menu-toggle"
  class="relative z-50 md:hidden p-2 text-graphite"
  aria-label={t('menu.open')}
  aria-expanded="false"
  aria-controls="mobile-menu"
>
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
  </svg>
</button>

<!-- Mobile menu panel -->
<div id="mobile-menu" class="hidden fixed inset-x-0 top-0 bottom-0 z-40 bg-white pt-[73px] md:hidden">
  <nav class="flex flex-col px-6 py-8 gap-6">
    {navItems.map(({ label, canonical }) => (
      <a
        href={getLocalizedPath(lang, canonical)}
        class:list={[
          'text-lg font-medium transition-colors',
          canonicalPath === canonical ? 'text-ember' : 'text-graphite',
        ]}
      >
        {label}
      </a>
    ))}
    <div class="pt-4 border-t border-gray-200">
      <a
        href={getLocalizedPath(altLang, canonicalPath)}
        class="text-sm font-medium text-steel hover:text-ember transition-colors"
      >
        {altLang === 'de' ? 'Deutsch' : 'English'}
      </a>
    </div>
  </nav>
</div>

<script is:inline>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', !isOpen);
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });
</script>
