---
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
  canonicalPath: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const logos = import.meta.glob('/src/assets/logos/mako/logo-horizontal-white.svg', { query: '?raw', import: 'default', eager: true });
const logoSvg = logos['/src/assets/logos/mako/logo-horizontal-white.svg'] as string;

const navItems = [
  { label: t('nav.home'), canonical: '/' },
  { label: t('nav.services'), canonical: '/services' },
  { label: t('nav.about'), canonical: '/about' },
  { label: t('nav.contact'), canonical: '/contact' },
];

const legalItems = [
  { label: t('footer.imprint'), canonical: '/imprint' },
  { label: t('footer.privacy'), canonical: '/privacy' },
];
---

<footer class="bg-graphite text-white py-16">
  <Container>
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Logo & tagline -->
      <div>
        <span class="block w-48 [&>svg]:w-full [&>svg]:h-auto mb-4" set:html={logoSvg} />
        <p class="text-sm text-gray-400 leading-relaxed">
          {lang === 'de'
            ? 'Strategische Marketingberatung in Hamburg. Positionierung, Botschaften, Wachstum. Strategie, die auf echtem Verstehen basiert.'
            : 'Strategic marketing consultancy based in Hamburg. Helping companies find clarity on positioning, messaging, and growth.\u200AStrategy built from understanding first.'}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <nav class="flex flex-col gap-3">
          {navItems.map(({ label, canonical }) => (
            <a
              href={getLocalizedPath(lang, canonical)}
              class="text-sm text-gray-300 hover:text-white transition-colors"
            >
              {label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Legal -->
      <div>
        <nav class="flex flex-col gap-3">
          {legalItems.map(({ label, canonical }) => (
            <a
              href={getLocalizedPath(lang, canonical)}
              class="text-sm text-gray-300 hover:text-white transition-colors"
            >
              {label}
            </a>
          ))}
        </nav>
        <a
          href="https://www.linkedin.com/in/mmakowiecki/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-4 text-gray-400 hover:text-white transition-colors"
          aria-label="LinkedIn"
        >
          <Icon name="linkedin-bw" class="w-6 h-6 [&>svg]:w-6 [&>svg]:h-6 brightness-0 invert" />
        </a>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-700">
      <p class="text-sm text-gray-500">
        {t('footer.copyright').replace('{year}', String(year))}
      </p>
    </div>
  </Container>
</footer>
