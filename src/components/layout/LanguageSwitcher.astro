---
import { getLocalizedPath, getAlternateLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
  canonicalPath: string;
}

const { lang, canonicalPath } = Astro.props;
const enUrl = getLocalizedPath('en', canonicalPath);
const deUrl = getLocalizedPath('de', canonicalPath);
---

<div class="flex items-center gap-1 text-sm font-medium">
  <a
    href={enUrl}
    class:list={[
      'lang-link relative pb-1 transition-colors hover:text-ember',
      lang === 'en' ? 'text-ember font-semibold active' : 'text-steel',
    ]}
  >
    EN
  </a>
  <span class="text-steel/40">|</span>
  <a
    href={deUrl}
    class:list={[
      'lang-link relative pb-1 transition-colors hover:text-ember',
      lang === 'de' ? 'text-ember font-semibold active' : 'text-steel',
    ]}
  >
    DE
  </a>
</div>

<style>
  .lang-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    height: 2px;
    width: 0;
    background-color: var(--color-ember);
    transition: width 0.3s ease;
  }

  .lang-link.active::after {
    width: 100%;
  }

  .lang-link:hover::after {
    width: 100%;
  }
</style>
